############################################################
# Atlas Backend Environment (example)
#
# Create your local env file at backend/.env (do not commit it)
# and copy values from here.
#
# NOTE: Never commit real secrets.
############################################################

# Server
PORT=5001
NODE_ENV=development

# Auth
JWT_SECRET=change-me

# --- AI Providers ---

# OpenAI (chat + whisper transcription)
OPENAI_API_KEY=sk-your-openai-key
# Optional: override the chat model used in /api/roleplay/conversation-turn
OPENAI_CHAT_MODEL=gpt-4
# Optional: override the transcription model used in /api/roleplay/transcribe
OPENAI_TRANSCRIBE_MODEL=whisper-1

# Deepgram (streaming STT over WebSocket)
DEEPGRAM_API_KEY=your-deepgram-key
# Optional: override Deepgram stream config
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en-US

# ElevenLabs (premium TTS)
ELEVENLABS_API_KEY=your-elevenlabs-key
# Optional defaults for ElevenLabs
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2


